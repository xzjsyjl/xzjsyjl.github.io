---
import '../styles/global.css';

export interface Props { title: string; }

const { title } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="PSQ" href="/rss.xml" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <title>{title}</title>
  </head>
  <body>
    <header class="arxiv-header">
      <div class="arxiv-header-inner">
        <div class="arxiv-logo">
          <a href="/">PSQ</a>
        </div>
        <nav class="arxiv-nav">
          <a href="/">首页</a>
          <a href="/blog/">文章</a>
          <a href="/tags/">分类</a>
          <a href="/search">搜索</a>
        </nav>
      </div>
    </header>

    <main>
      <div class="content-area">
        <slot />
      </div>
    </main>

    <footer class="arxiv-footer">
      <div class="arxiv-footer-inner">
        <span>PSQ &mdash; 技术文章存档</span>
        <span>
          <a href="/">首页</a> &middot;
          <a href="/blog/">文章</a> &middot;
          <a href="/tags/">分类</a> &middot;
          <a href="/search">搜索</a> &middot;
          <a href="/rss.xml">订阅</a>
        </span>
      </div>
    </footer>
  </body>
</html>
