---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const tagCounts = new Map<string, number>();
for (const p of posts) for (const t of p.data.tags) tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
const sortedTags = [...tagCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<Layout title="PSQ">
  <p class="home-desc">
    PSQ 是一个免费的技术文章存档，收录了关于编程、数学、物理与技术的内容。
    本站文章以响应式 HTML5 网页呈现，支持 LaTeX 数学公式。
  </p>

  <div class="home-search-row">
    <label for="subject-select">分类搜索与浏览：</label>
    <select id="subject-select" onchange="location.href = this.value;">
      <option value="">-- 选择分类 --</option>
      {sortedTags.map(([tag]) => (
        <option value={`/tags/${tag}/`}>{tag}</option>
      ))}
    </select>
    <button class="primary" onclick="const v=document.getElementById('subject-select').value;if(v)location.href=v;">搜索</button>
    <a href="/search" class="btn">高级搜索</a>
  </div>

  <!-- Recent listing -->
  <div class="cat-section">
    <div class="cat-heading">最新文章</div>
    <div class="article-listing">
      {sortedPosts.slice(0, 5).map((post, i) => (
        <div class="article-entry">
          <div class="arxiv-title-row">
            <span class="arxiv-item-num">PSQ-{String(i + 1).padStart(4, '0')}</span>
            <div class="arxiv-item-title">
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </div>
          </div>
          <div class="arxiv-item-desc">{post.data.description}</div>
          <div class="arxiv-item-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              [{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}]
            </time>
            {post.data.tags.length > 0 && (
              <span class="tags">
                {post.data.tags.map((tag) => (
                  <a href={`/tags/${tag}/`} class="tag">{tag}</a>
                ))}
              </span>
            )}
          </div>
        </div>
      ))}
    </div>
    <p style="font-size:0.72rem;margin:6px 0;">
      <a href="/blog/">更多 &raquo;</a>
    </p>
  </div>

  <!-- Subjects -->
  <div class="cat-section">
    <div class="cat-heading">分类</div>
    <div class="categories-grid">
      {sortedTags.map(([tag, count]) => (
        <div class="category-item">
          <span class="category-code">{tag}</span>
          <a href={`/tags/${tag}/`} class="category-name">{tag}</a>
          <span class="category-count">({count})</span>
        </div>
      ))}
    </div>
  </div>
</Layout>
