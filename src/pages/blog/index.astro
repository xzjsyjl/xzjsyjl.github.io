---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sorted = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="文章 — PSQ">
  <div class="all-articles-title">全部文章</div>
  <div class="all-articles-meta">共 {sorted.length} 篇</div>

  <div class="article-listing">
    {sorted.map((post, i) => (
      <div class="article-entry">
        <div class="arxiv-title-row">
          <span class="arxiv-item-num">PSQ-{String(i + 1).padStart(4, '0')}</span>
          <div class="arxiv-item-title">
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          </div>
        </div>
        <div class="arxiv-item-desc">{post.data.description}</div>
        <div class="arxiv-item-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            [{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}]
          </time>
          {post.data.tags.length > 0 && (
            <span class="tags">
              {post.data.tags.map((tag) => (
                <a href={`/tags/${tag}/`} class="tag">{tag}</a>
              ))}
            </span>
          )}
        </div>
      </div>
    ))}
  </div>
</Layout>
